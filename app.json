{
  "expo": {
    "name": "AYOMI",
    "slug": "posyandu-mobile",
    "owner": "samsi_wahyudi",
    "scheme": "posyandu-mobile",
    "platforms": [
      "ios",
      "android"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ayomi-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ayomi-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.posyandu.mobile"
    },
    "android": {
      "package": "com.posyandu.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/ayomi-adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/ec27093a-a127-479c-adae-98674e5846a6",
      "enabled": true,
      "checkOnLaunch": "ALWAYS"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-updates",
      "expo-sharing",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec27093a-a127-479c-adae-98674e5846a6"
      }
    }
  }
}
